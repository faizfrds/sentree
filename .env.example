# ─── Roboflow / YOLO ──────────────────────────────────────────────────────────
# Required. Get this from app.roboflow.com → your workspace → Settings → API Keys
ROBOFLOW_API_KEY="your_roboflow_api_key_here"

# ─── Redis ────────────────────────────────────────────────────────────────────
# Defaults to local docker-compose Redis. Override for a remote instance.
REDIS_URL="redis://localhost:6379"

# ─── Kafka ────────────────────────────────────────────────────────────────────
# Comma-separated broker list. Defaults to local docker-compose Kafka.
KAFKA_BROKERS="localhost:9092"

# ─── Satellite Imagery ────────────────────────────────────────────────────────
# NASA GIBS is used by default (free, no key required).
# No additional keys needed for satellite imagery.

# ─── App (optional) ───────────────────────────────────────────────────────────
# NODE_ENV="production"
